# ============================================
# Smart Attendance System - Environment Config
# ============================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/smart_attendance
# For Docker: mongodb://mongo:27017/smart_attendance

# JWT Secret (change this to a long random string in production!)
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRE=7d

# Admin Default Credentials (used during seed)
ADMIN_EMAIL=admin@company.com
ADMIN_PASSWORD=Admin@123456

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads
